{
    "name": "reply-cli",
    "version": "0.1.1",
    "description": "Command-line interface for Reply.io. Manage sequences, contacts, email accounts, and schedules from your terminal.",
    "main": "dist/index.js",
    "bin": {
        "reply": "dist/index.js"
    },
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "start": "node dist/index.js",
        "clean": "rm -rf dist",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:integration": "vitest run --testPathPattern integration"
    },
    "author": "Reply.io",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/replyio/reply-cli.git"
    },
    "bugs": {
        "url": "https://github.com/replyio/reply-cli/issues"
    },
    "homepage": "https://github.com/replyio/reply-cli#readme",
    "engines": {
        "node": ">=20.0.0"
    },
    "files": [
        "dist",
        "README.md"
    ],
    "devDependencies": {
        "@types/node": "^20.0.0",
        "typescript": "^5.0.0",
        "vitest": "^4.0.0"
    },
    "dependencies": {
        "commander": "^14.0.2",
        "picocolors": "^1.1.1"
    }
}
